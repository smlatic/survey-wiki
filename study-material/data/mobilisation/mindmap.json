    {
      "name": "AHRS Calibration",
      "children": [
        {
          "name": "GNSS Attitude Reference",
          "children": [
            {"name": "Multi-antenna baseline vectors"},
            {"name": "Integer ambiguity resolution"},
            {"name": "Heading accuracy: 0.229/L deg"},
            {"name": "Pitch/roll accuracy: 0.372/L deg"}
          ]
        },
        {
          "name": "Procedure",
          "children": [
            {"name": "Remove existing C-O corrections first"},
            {"name": "Static logging: min 1 hour alongside"},
            {"name": "Dynamic logging: box pattern, 15 min per heading"},
            {"name": "ROV gyro: two orientations (0 and 180 deg)"}
          ]
        },
        {
          "name": "Acceptance Criteria",
          "children": [
            {"name": "Heading GNSS vs gyro: < 0.5 deg"},
            {"name": "Pitch/roll GNSS vs MRU: < 0.1 deg"},
            {"name": "Heading C-O SD: < 0.10 deg"},
            {"name": "Max HDOP/VDOP: 3.0"}
          ]
        }
      ]
    },
    {
      "name": "Gyro Types and Calibration",
      "children": [
        {
          "name": "Gyro Types",
          "children": [
            {"name": "Spinning mass: +/-0.2 deg x sec(lat), 4-6 hr settle"},
            {"name": "FOG: +/-0.1 deg x sec(lat), 20-30 min settle"},
            {"name": "RLG: <0.05 deg x sec(lat), <5 min settle"},
            {"name": "GAMS: +/-0.02 deg (2m baseline), 2-10 min"}
          ]
        },
        {
          "name": "Calibration Methods",
          "children": [
            {"name": "Dual total station (quayside)"},
            {"name": "GNSS compass comparison"},
            {"name": "ROV LARS reference + tape"},
            {"name": "Structure yard calibration"}
          ]
        },
        {
          "name": "Key Considerations",
          "children": [
            {"name": "Speed error (E-W heading dependent)"},
            {"name": "Convergence (True vs Grid North)"},
            {"name": "UPS mandatory for power protection"},
            {"name": "24-hour bench test before deployment"}
          ]
        }
      ]
    },
    {
      "name": "Heave and MRU",
      "children": [
        {
          "name": "Heave Measurement Methods",
          "children": [
            {"name": "Double integration of accelerations (traditional)"},
            {"name": "GNSS-derived heave (10-20 Hz RTK/PPP)"},
            {"name": "Hybrid INS/GNSS blended (best approach)"},
            {"name": "Delayed heave: 150 s buffer, non-causal filter"}
          ]
        },
        {
          "name": "Heave Filter Period",
          "children": [
            {"name": "Must exceed swell period by 20%"},
            {"name": "Too short: attenuates real heave signal"},
            {"name": "Typical range: 10-20 seconds"}
          ]
        },
        {
          "name": "Lever-Arm-Induced Heave",
          "children": [
            {"name": "Formula: Lx sin(pitch) + Ly sin(roll)"},
            {"name": "10 m arm, 3 deg pitch = 0.52 m error"},
            {"name": "Mount MRU near centre of rotation"}
          ]
        },
        {
          "name": "Settlement and Squat",
          "children": [
            {"name": "Settlement: Bernoulli effect, speed-squared"},
            {"name": "Squat: trim change, hull-form dependent"},
            {"name": "Typical 0.05-0.30 m at survey speed"},
            {"name": "Measured by speed runs over known depth"}
          ]
        }
      ]
    },
    {
